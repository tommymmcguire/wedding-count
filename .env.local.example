# Copy this file to .env.local and fill in the values.
# In Vercel, add these as Environment Variables in the project settings.

# The Sheet ID from the guest-list Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# The name of the tab (worksheet) containing the guest list. Defaults to "Guests".
GOOGLE_SHEET_TAB=Guests

# Service account email from the Google Cloud JSON key file.
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key from the JSON key file.
# In .env.local, keep the literal \n sequences (do NOT convert to real newlines);
# the app decodes them at runtime.
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
